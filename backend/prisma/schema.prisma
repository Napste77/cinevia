// Esquema de la base de datos propia de NowSee.
//
// Diseño: Movies y TVShows son las entidades "de contenido" propiamente
// dichas. StreamingLink, ContentCast, Video, Image y SimilarContent son
// compartidas entre ambas (un mismo link de streaming, elenco, tráiler,
// imagen o "similar" puede apuntar a una película o a una serie), así que
// usan un par (contentType, contentId) en vez de una FK directa: Prisma no
// soporta asociaciones polimórficas nativas, así que la integridad
// referencial de esas tablas se valida en la capa de servicios (ver
// src/services), no con una FK de base de datos.
//
// Importante: poster/backdrop/logo/photo son SIEMPRE referencias (path
// relativo de TMDB + `source`), nunca el binario de la imagen — la URL
// completa se arma en el momento de servir la respuesta (ver
// src/utils/media.ts), así el día que cambiemos de fuente de imágenes
// alcanza con tocar un solo lugar.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  // MySQL: es lo que trae cualquier plan de Hostinger (compartido, cloud o
  // VPS con el gestor de bases de datos de hPanel), así no depende de que
  // el usuario instale Postgres a mano.
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  movie
  tv
}

enum SyncStatus {
  pending
  synced
  error
}

enum VideoType {
  trailer
  teaser
  clip
}

enum ImageType {
  poster
  backdrop
  logo
}

enum AuthProvider {
  email
  google
  apple
}

enum RegionSource {
  detected
  manual
}

model Movie {
  id            Int      @id @default(autoincrement())
  tmdbId        Int      @unique @map("tmdb_id")
  imdbId        String?  @map("imdb_id")
  title         String
  originalTitle String?  @map("original_title")
  overview      String?  @db.Text
  releaseDate   DateTime? @map("release_date")
  runtime       Int?
  rating        Float     @default(0)
  popularity    Float     @default(0)
  poster        String?   // path relativo, ej "/abc123.jpg"
  posterSource  String    @default("tmdb") @map("poster_source")
  backdrop      String?
  backdropSource String   @default("tmdb") @map("backdrop_source")
  language      String?   @map("original_language")
  status        String?

  lastSync      DateTime?  @map("last_sync")
  syncStatus    SyncStatus @default(pending) @map("sync_status")
  lastError     String?    @db.Text @map("last_error")
  lastMediaSync DateTime?  @map("last_media_sync")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  genres MovieGenre[]

  @@index([popularity])
  @@index([releaseDate])
  @@fulltext([title, originalTitle])
  @@map("movies")
}

model TVShow {
  id            Int      @id @default(autoincrement())
  tmdbId        Int      @unique @map("tmdb_id")
  imdbId        String?  @map("imdb_id")
  title         String
  originalTitle String?  @map("original_title")
  overview      String?  @db.Text
  seasons       Int?
  episodes      Int?
  firstAirDate  DateTime? @map("first_air_date")
  lastAirDate   DateTime? @map("last_air_date")
  rating        Float     @default(0)
  popularity    Float     @default(0)
  poster        String?
  posterSource  String    @default("tmdb") @map("poster_source")
  backdrop      String?
  backdropSource String   @default("tmdb") @map("backdrop_source")
  language      String?   @map("original_language")
  status        String?

  lastSync      DateTime?  @map("last_sync")
  syncStatus    SyncStatus @default(pending) @map("sync_status")
  lastError     String?    @db.Text @map("last_error")
  lastMediaSync DateTime?  @map("last_media_sync")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  genres TVGenre[]

  @@index([popularity])
  @@index([firstAirDate])
  @@fulltext([title, originalTitle])
  @@map("tv_shows")
}

model Genre {
  id     Int    @id @default(autoincrement())
  tmdbId Int    @unique @map("tmdb_id")
  name   String

  movies MovieGenre[]
  tvShows TVGenre[]

  @@map("genres")
}

model MovieGenre {
  movieId Int @map("movie_id")
  genreId Int @map("genre_id")

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
  @@index([genreId])
  @@map("movie_genres")
}

model TVGenre {
  tvShowId Int @map("tv_show_id")
  genreId  Int @map("genre_id")

  tvShow TVShow @relation(fields: [tvShowId], references: [id], onDelete: Cascade)
  genre  Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([tvShowId, genreId])
  @@index([genreId])
  @@map("tv_genres")
}

/// Catálogo estático de plataformas de streaming (Netflix, Disney+, etc).
model Platform {
  id        Int      @id @default(autoincrement())
  tmdbId    Int?     @unique @map("tmdb_id")
  name      String
  slug      String   @unique
  logo      String?
  color     String?
  website   String?
  createdAt DateTime @default(now()) @map("created_at")

  streamingLinks StreamingLink[]
  availability   PlatformAvailability[]

  @@map("platforms")
}

/// Deep links/URLs resueltos por título+plataforma+país. Es la versión
/// server-side de lo que hoy resuelve src/api/streamingLinks.ts en el
/// frontend (Wikidata + Streaming Availability API), cacheado en la DB en
/// vez de recalcularse en cada visita.
model StreamingLink {
  id                Int      @id @default(autoincrement())
  contentType       ContentType @map("content_type")
  contentId         Int      @map("content_id")
  platformId        Int      @map("platform_id")
  providerContentId String?  @map("provider_content_id")
  providerUrl       String?  @db.Text @map("provider_url")
  androidDeepLink   String?  @db.Text @map("android_deep_link")
  iosUniversalLink  String?  @db.Text @map("ios_universal_link")
  country           String
  verified          Boolean  @default(false)
  lastChecked       DateTime? @map("last_checked")

  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([contentType, contentId, platformId, country], name: "content_platform_country")
  @@index([contentType, contentId])
  @@map("streaming_links")
}

model Cast {
  id     Int    @id @default(autoincrement())
  tmdbId Int    @unique @map("tmdb_id")
  name   String
  photo  String?
  photoSource String @default("tmdb") @map("photo_source")

  credits ContentCast[]

  @@map("cast_members")
}

model ContentCast {
  id          Int    @id @default(autoincrement())
  contentType ContentType @map("content_type")
  contentId   Int    @map("content_id")
  actorId     Int    @map("actor_id")
  character   String?
  order       Int?

  actor Cast @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([contentType, contentId, actorId])
  @@index([contentType, contentId])
  @@map("content_cast")
}

model Video {
  id          Int       @id @default(autoincrement())
  contentType ContentType @map("content_type")
  contentId   Int       @map("content_id")
  type        VideoType
  site        String    @default("YouTube")
  youtubeId   String    @map("youtube_id")
  official    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([contentType, contentId, youtubeId])
  @@index([contentType, contentId])
  @@map("videos")
}

/// Imágenes adicionales (galería de posters/backdrops/logos alternativos).
/// `filePath` es SIEMPRE el path relativo de la fuente (TMDB u otra), nunca
/// el binario — ver nota de diseño arriba.
model Image {
  id          Int       @id @default(autoincrement())
  contentType ContentType @map("content_type")
  contentId   Int       @map("content_id")
  type        ImageType
  filePath    String    @map("file_path")
  source      String    @default("tmdb")
  width       Int?
  height      Int?
  language    String?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([contentType, contentId, type])
  @@map("images")
}

/// Recomendaciones/"contenido similar" pre-calculadas (hoy vienen del
/// endpoint /recommendations de TMDB; a futuro puede alimentarse de un
/// motor propio de recomendaciones con IA sin cambiar el resto del sistema).
model SimilarContent {
  id            Int      @id @default(autoincrement())
  contentAType  ContentType @map("content_a_type")
  contentAId    Int      @map("content_a_id")
  contentBType  ContentType @map("content_b_type")
  contentBId    Int      @map("content_b_id")
  score         Float    @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([contentAType, contentAId, contentBType, contentBId])
  @@index([contentAType, contentAId])
  @@map("similar_content")
}

// ---------------------------------------------------------------------
// Cuentas de usuario, región, calificaciones, comentarios, listas.
//
// Uso sin cuenta sigue andando igual (navegar, buscar, ver fichas,
// providers) — todo lo de acá abajo es opt-in y gatea recién en la capa
// de rutas (ver src/middleware/auth.ts: optionalAuth vs requireAuth).
// ---------------------------------------------------------------------

model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  /// null si la cuenta es de Google/Apple (no tiene password propia acá).
  passwordHash String?      @map("password_hash")
  name         String?
  avatarUrl    String?      @map("avatar_url")
  language     String       @default("es")
  /// Región activa (ISO 3166-1 alpha-2). Null hasta la primera detección.
  country      String?
  authProvider AuthProvider @default(email) @map("auth_provider")
  /// `sub` de Google/Apple cuando el login es con esos providers.
  providerId   String?      @map("provider_id")

  // "Preparado para futuras versiones" (spec): el toggle ya existe y se
  // persiste, falta el envío real de notificaciones.
  notifyNewReleases Boolean @default(true) @map("notify_new_releases")
  notifyComments    Boolean @default(true) @map("notify_comments")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions            UserSession[]
  regions             UserRegion[]
  ratings             UserRating[]
  comments            UserComment[]
  favorites           UserFavorite[]
  lists               UserList[]
  views               UserView[]
  passwordResetTokens PasswordResetToken[]

  @@unique([authProvider, providerId], name: "provider_identity")
  @@map("users")
}

/// Refresh tokens activos (uno por login/dispositivo). Permite "cerrar
/// sesión" real (revocar) y es la base de la sincronización entre
/// dispositivos: cada dispositivo logueado tiene su propia sesión acá.
model UserSession {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  createdAt        DateTime  @default(now()) @map("created_at")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

/// Token de "recuperar contraseña": se genera uno opaco random, se manda
/// por email, y acá solo se guarda su hash (mismo patrón que el refresh
/// token de UserSession — si la DB se filtra, no alcanza para resetear la
/// contraseña de nadie). Expira a las 2hs y se marca `usedAt` al primer uso
/// para que no sea reutilizable ni siquiera dentro de la ventana de validez.
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @map("token_hash")
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// Historial de cambios de región (detectada al ingresar + cada cambio
/// manual desde el perfil). `User.country` siempre tiene la última.
model UserRegion {
  id        Int          @id @default(autoincrement())
  userId    Int          @map("user_id")
  country   String
  source    RegionSource
  createdAt DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_regions")
}

/// Calificación propia de NowSee (1-10), una por usuario+contenido — NO
/// reemplaza el rating de TMDB, se muestran ambos por separado (ver
/// src/serializers.ts).
model UserRating {
  id          Int         @id @default(autoincrement())
  userId      Int         @map("user_id")
  contentType ContentType @map("content_type")
  contentId   Int         @map("content_id")
  value       Int
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType, contentId])
  @@index([contentType, contentId])
  @@index([userId])
  @@map("user_ratings")
}

model UserComment {
  id          Int         @id @default(autoincrement())
  userId      Int         @map("user_id")
  contentType ContentType @map("content_type")
  contentId   Int         @map("content_id")
  body        String      @db.Text
  /// Preparado para respuestas anidadas (no expuesto en la UI todavía).
  parentId    Int?        @map("parent_id")
  /// Preparado para likes (no expuesto en la UI todavía).
  likesCount  Int         @default(0) @map("likes_count")
  /// Preparado para reportes de moderación (no expuesto en la UI todavía).
  reported    Boolean     @default(false)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  UserComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies UserComment[] @relation("CommentReplies")

  @@index([contentType, contentId])
  @@index([userId])
  @@map("user_comments")
}

/// "Mi Lista": acceso rápido desde la card, una sola lista implícita por
/// usuario. Las listas con nombre propio (a futuro) son UserList/UserListItem.
model UserFavorite {
  id          Int         @id @default(autoincrement())
  userId      Int         @map("user_id")
  contentType ContentType @map("content_type")
  contentId   Int         @map("content_id")
  createdAt   DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType, contentId])
  @@index([userId])
  @@map("user_favorites")
}

/// Listas personalizadas con nombre (ej. "Para ver en pareja"). Preparado
/// para la UI de "Crear listas" — hoy "Mi Lista" (UserFavorite) alcanza
/// para el MVP, esto ya deja la base para listas múltiples.
model UserList {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items UserListItem[]

  @@index([userId])
  @@map("user_lists")
}

model UserListItem {
  id          Int         @id @default(autoincrement())
  listId      Int         @map("list_id")
  contentType ContentType @map("content_type")
  contentId   Int         @map("content_id")
  addedAt     DateTime    @default(now()) @map("added_at")

  list UserList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, contentType, contentId])
  @@map("user_list_items")
}

/// Marca "visto" (se registra solo al abrir una ficha estando logueado) —
/// alimenta la estadística "películas/series vistas" del perfil.
model UserView {
  id          Int         @id @default(autoincrement())
  userId      Int         @map("user_id")
  contentType ContentType @map("content_type")
  contentId   Int         @map("content_id")
  viewedAt    DateTime    @default(now()) @map("viewed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType, contentId])
  @@index([userId])
  @@map("user_views")
}

/// Catálogo de países soportados (selector de región del perfil +
/// detección por IP).
model Country {
  id   Int    @id @default(autoincrement())
  code String @unique
  name String

  platforms PlatformAvailability[]

  @@map("countries")
}

/// Qué plataforma opera en qué país — independiente de qué títulos
/// puntuales tenga cada una ahí (eso es StreamingLink). Alimenta el
/// filtro de plataformas por región y el paso 1 de "mostrar las
/// plataformas disponibles para esa región".
model PlatformAvailability {
  id         Int @id @default(autoincrement())
  platformId Int @map("platform_id")
  countryId  Int @map("country_id")

  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  country  Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([platformId, countryId])
  @@map("platform_availability")
}
