DATABASE_URL="mysql://usuario:password@localhost:3306/nowsee"
PORT=4000

# TMDB: solo el backend lo usa. Nunca se expone al frontend.
TMDB_API_KEY="tu_tmdb_api_key_aca"

# Opcional: Streaming Availability API (RapidAPI).
STREAMING_AVAILABILITY_API_KEY=""

DEFAULT_COUNTRY="AR"

# Secreto compartido para disparar los jobs de sincronización vía HTTP
# (POST /internal/sync/:job con header X-Sync-Secret).
SYNC_SECRET="cambia_este_secreto"

# "true" en un VPS donde el server corre siempre (usa node-cron interno).
# "false" en hosting compartido: programar un Cron Job de hPanel (o un cron
# externo) que pegue al endpoint /internal/sync/:job en su lugar.
ENABLE_INTERNAL_CRON="false"
